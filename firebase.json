{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "database.rules.json",
      "**/.*",
      ".git/**",
      ".firebase/**",
      "**/node_modules/**",
      "tests/**",
      "README.md",
      "CHANGELOG.md"
    ],
    "headers": [
      { "source": "/", "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0" }] },
      { "source": "**/*.html", "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0" }] }
    ]
  }
}
